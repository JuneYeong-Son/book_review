generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  name         String
  passwordHash String
  avatar       String       @default("📚") // 회원가입 시 고른 이모지 아바타
  createdAt    DateTime     @default(now())
  progresses   Progress[]
  interests    Interest[]
  discussions  Discussion[]
  comments     Comment[]
  likes        Like[]
  notifications Notification[]
  reviewComments ReviewComment[]
}

model Book {
  id          String       @id @default(cuid())
  title       String
  author      String
  cover       String
  genre       String       @default("") // 추천 시스템(콘텐츠 기반)용
  category    String       @default("") // 추천 시스템(콘텐츠 기반)용
  isbn        String?      @unique       // 알라딘 등 외부 임포트 중복 방지 (수동 추가 책은 null)
  publisher   String       @default("")
  description String       @default("")
  createdAt   DateTime     @default(now())
  progresses  Progress[]
  interests   Interest[]
  discussions Discussion[]
}

// 독서 기록 + 서평. 기록할 때마다 새 항목이 쌓여 날짜별 이력이 된다.
// (책 1권에 대해 사용자가 여러 번 기록 가능)
model Progress {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  startPage Int      @default(0)  // 몇 페이지부터
  endPage   Int      @default(0)  // 몇 페이지까지
  note      String   @default("") // 서평 내용
  quote     String   @default("") // 인상깊은 글귀 (선택)
  rating    Int      @default(0)  // 별점 0(미평가)~5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])
  likes     Like[]
  comments  ReviewComment[]

  @@index([userId, bookId])
}

// 서평(Progress)에 달리는 댓글
model ReviewComment {
  id         String   @id @default(cuid())
  progressId String
  userId     String
  text       String
  createdAt  DateTime @default(now())
  progress   Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
}

// 서평(Progress)에 대한 좋아요
model Like {
  id         String   @id @default(cuid())
  userId     String
  progressId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  progress   Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([userId, progressId])
}

// 알림: 내 토론에 댓글이 달리거나 내 서평에 좋아요가 눌리면 생성
model Notification {
  id        String   @id @default(cuid())
  userId    String   // 받는 사람
  type      String   // 'comment' | 'like'
  message   String
  link      String   // 클릭 시 이동할 경로
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// 관심 있는 책 지정
model Interest {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

// 자신이 읽거나 읽는 중인 책에 대해 여는 토론
model Discussion {
  id          String    @id @default(cuid())
  bookId      String
  ownerId     String
  title       String
  description String    @default("")
  createdAt   DateTime  @default(now())
  book        Book      @relation(fields: [bookId], references: [id])
  owner       User      @relation(fields: [ownerId], references: [id])
  comments    Comment[]
}

// 토론에 누구나 남길 수 있는 댓글
model Comment {
  id           String     @id @default(cuid())
  discussionId String
  userId       String
  text         String
  createdAt    DateTime   @default(now())
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])
}

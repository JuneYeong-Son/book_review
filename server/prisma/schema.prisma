generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String?      @unique // 이메일 인증 가입(중복 불가). 기존 계정은 null 허용
  name         String
  nickname     String?      @unique // 활동 표시명(중복 불가). 없으면 name으로 폴백
  phone        String?      // 휴대폰 번호(회원가입 시 수집)
  agreedAt     DateTime?    // 개인정보 수집·이용 동의 시각
  provider     String?      // 소셜 로그인 제공자 ('kakao' | 'google'). 일반 가입은 null
  providerId   String?      // 제공자 측 사용자 고유 ID
  passwordHash String
  isAdmin      Boolean      @default(false) // 관리자 여부(서버 통제). 유저명 매칭 대신 이 값으로 판정
  suspended    Boolean      @default(false) // 활동 정지(관리자가 통제). 로그인·인증 차단
  avatar       String       @default("📚") // 회원가입 시 고른 이모지 아바타
  birthYear    Int?         // 연령대별 추천 집계용 (선택 입력)
  lastSeenAt   DateTime?    // 오늘의 접속자 집계용
  createdAt    DateTime     @default(now())
  progresses   Progress[]
  interests    Interest[]
  discussions  Discussion[]
  comments     Comment[]
  likes        Like[]
  notifications Notification[]
  reviewComments ReviewComment[]
  reports      Report[]
  recoExclusions RecoExclusion[]
  ratings      Rating[]

  @@unique([provider, providerId]) // 같은 소셜 계정 중복 생성 방지
}

// 이메일 인증 대기(가입 확정 전 임시 저장). 인증 성공 시 User로 승격하고 삭제한다.
model EmailVerification {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String
  name         String
  nickname     String
  phone        String   @default("")
  passwordHash String
  avatar       String   @default("📚")
  birthYear    Int?
  code         String   // 6자리 인증 코드
  expiresAt    DateTime // 만료 시각
  createdAt    DateTime @default(now())
}

// 사용자 피드백 / 버그 신고. 비로그인도 남길 수 있어 User와 하드 관계를 두지 않고,
// 제출 시점의 작성자 이름을 함께 저장한다(작성자 삭제와 무관하게 보존).
model Feedback {
  id        String   @id @default(cuid())
  userId    String?  // 로그인 상태면 기록(참고용, FK 아님)
  name      String   @default("익명") // 제출 시점 이름
  kind      String   @default("feedback") // 'feedback' | 'bug'
  message   String
  page      String   @default("") // 남긴 화면 경로(선택)
  resolved  Boolean  @default(false) // 관리자 처리 여부
  createdAt DateTime @default(now())
}

// 공지사항 (관리자만 작성·수정·삭제, 모두 열람)
model Notice {
  id        String   @id @default(cuid())
  title     String
  body      String
  pinned    Boolean  @default(false) // 상단 고정
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id          String       @id @default(cuid())
  title       String
  author      String
  cover       String
  genre       String       @default("") // 추천 시스템(콘텐츠 기반)용
  category    String       @default("") // 추천 시스템(콘텐츠 기반)용
  isbn        String?      @unique       // 알라딘 등 외부 임포트 중복 방지 (수동 추가 책은 null)
  publisher   String       @default("")
  description String       @default("")
  createdAt   DateTime     @default(now())
  progresses  Progress[]
  interests   Interest[]
  discussions Discussion[]
  recoExclusions RecoExclusion[]
  ratings     Rating[]
}

// 독서 기록 + 서평. 기록할 때마다 새 항목이 쌓여 날짜별 이력이 된다.
// (책 1권에 대해 사용자가 여러 번 기록 가능)
model Progress {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  bookSeq   Int      @default(1)  // 그 책 안에서의 서평 순번 (URL /books/:bookId/reviews/:bookSeq)
  startPage Int      @default(0)  // 몇 페이지부터
  endPage   Int      @default(0)  // 몇 페이지까지
  note      String   @default("") // 서평 내용
  quote     String   @default("") // 인상깊은 글귀 (선택)
  rating    Int      @default(0)  // 별점 0(미평가)~5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])
  likes     Like[]
  comments  ReviewComment[]

  @@index([userId, bookId])
}

// 서평(Progress)에 달리는 댓글
model ReviewComment {
  id         String   @id @default(cuid())
  progressId String
  userId     String
  text       String
  createdAt  DateTime @default(now())
  progress   Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
}

// 서평(Progress)에 대한 좋아요
model Like {
  id         String   @id @default(cuid())
  userId     String
  progressId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  progress   Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([userId, progressId])
}

// 신고: 서평(review) 또는 토론(discussion)에 대한 신고
model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetType String   // 'review' | 'discussion'
  targetId   String
  reason     String   @default("")
  createdAt  DateTime @default(now())
  reporter   User     @relation(fields: [reporterId], references: [id])

  @@unique([reporterId, targetType, targetId]) // 1인 1대상 1신고 (신고 남용 방지)
  @@index([targetType, targetId])
}

// 알림: 내 토론에 댓글이 달리거나 내 서평에 좋아요가 눌리면 생성
model Notification {
  id        String   @id @default(cuid())
  userId    String   // 받는 사람
  type      String   // 'comment' | 'like'
  message   String
  link      String   // 클릭 시 이동할 경로
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// 책 별점 (사용자 1명당 책 1개, 서평이 아니라 책 자체에 매김)
model Rating {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

// 추천 안 받을 책 리스트 (사용자별)
model RecoExclusion {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

// 관심 있는 책 지정
model Interest {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

// 자신이 읽거나 읽는 중인 책에 대해 여는 토론
model Discussion {
  id          String    @id @default(cuid())
  bookId      String
  ownerId     String
  title       String
  description String    @default("")
  createdAt   DateTime  @default(now())
  book        Book      @relation(fields: [bookId], references: [id])
  owner       User      @relation(fields: [ownerId], references: [id])
  comments    Comment[]
}

// 토론에 누구나 남길 수 있는 댓글
model Comment {
  id           String     @id @default(cuid())
  discussionId String
  userId       String
  text         String
  createdAt    DateTime   @default(now())
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])
}

# 데이터베이스 (PostgreSQL)
# 로컬(Docker): docker compose up -d 후 아래 값 사용
DATABASE_URL="postgresql://book:book@localhost:5432/book_review?schema=public"

# 알라딘 OpenAPI 인증키 (https://www.aladin.co.kr/ttb/apiguide.aspx 에서 발급)
ALADIN_TTB_KEY=""

# 배포 시: 프론트엔드 주소(들). 쉼표로 여러 개 가능. 로컬은 비워두면 http://localhost:5173
# FRONTEND_URL="https://book-review-frontend.onrender.com"

# 배포 시 production 으로 (cross-site 쿠키 활성화). Render가 자동 주입하기도 함.
# NODE_ENV="production"

# 관리자 계정(아이디, 쉼표 구분). 기본값 reader.
# ADMIN_USERNAMES="reader"
